{
  "expo": {
    "name": "AutoAlarm",
    "slug": "AutoAlarm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AutoAlarm needs your location to calculate sunrise time and set accurate alarms.",
        "NSLocationAlwaysUsageDescription": "AutoAlarm needs your location to calculate sunrise time and set accurate alarms."
      }
    },
    "android": {
      "package": "com.autoalarm.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0A0A0F"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./withCustomRingtones.js",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#F5A623",
          "defaultChannel": "alarm"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AutoAlarm needs your location to calculate the sunrise time for your area."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "49941ed8-6b5b-479e-89b0-014598c6c211"
      }
    }
  }
}
